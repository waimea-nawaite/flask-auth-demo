{#=====================================================
  Help page
=====================================================#}

{% extends 'pages/base.jinja' %}


{% block content %}

<form method="POST">

    <label>Title</label>
    <input type="text"
           name="title"
           value="{{ message.title }}">

    <label>Body</label>
    <textarea name="body">{{ message.body }}</textarea>

    <button type="submit">
        Save Changes
    </button>

</form>

{% endblock %}

